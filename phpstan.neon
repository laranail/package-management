includes:
    - vendor/larastan/larastan/extension.neon

parameters:
    level: 6
    paths:
        - src
    excludePaths:
        - vendor
    ignoreErrors:
        # Facade @method tags + generic array docblocks are not enforced (laranail convention).
        -
            identifier: missingType.iterableValue
    treatPhpDocTypesAsCertain: false
